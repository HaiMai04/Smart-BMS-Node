     <string notr="true">/* Thiết lập cái rãnh (nền) của thanh pin */
QProgressBar {
    background-color: #131c2b; /* Màu xanh đen rất sâu, tệp với nền */
    border: none; /* Xóa viền hoàn toàn */
    border-radius: 4px; /* Bo góc nhẹ */
    text-align: center;
    color: transparent; /* Giấu số % đi */
}

/* Thiết lập phần lõi pin (Chunk) đang chạy */
QProgressBar::chunk {
    /* Chuyển màu từ Cyan (xanh ngọc) sang Lime (xanh lá sáng) */
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
        stop:0 #0dcaf0, 
        stop:1 #8cc63f);
    border-radius: 4px;
}</string>
    </property>
