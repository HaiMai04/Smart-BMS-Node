   <property name="styleSheet">
    <string notr="true">/* Khung nền chính (Sidebar) */
QFrame {
    background-color: #080c15; 
    border-right: 1px solid #151e2e;
    padding: 10px;
}

/* THÊM MỚI: Định dạng cho mọi chữ (Label) thả vào khung này sẽ auto màu Trắng */
QLabel {
    color: #ffffff; 
    background-color: transparent; /* Tẩy nền xám */
    font-size: 14px;
}

/* Các nút bấm (Giữ nguyên của chàng vì đã quá đẹp) */
QPushButton {
    color: #64748b; 
    text-align: left;
    padding-left: 15px;
    background-color: rgba(255, 255, 255, 0.02); 
    height: 52px; 
    font-size: 16px;
    font-weight: bold;
    border: 1px solid #0f172a;
    border-radius: 10px;
    margin-bottom: 12px;
}

QPushButton:hover {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 rgba(0, 212, 255, 0.1), stop:1 rgba(0, 0, 0, 0));
    color: #ffffff;
    border: 1px solid #1e293b;
}

QPushButton:pressed {
    background-color: rgba(0, 255, 204, 0.15);
    padding-top: 2px; 
    padding-left: 17px;
}

QPushButton:checked {
    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:0, 
        stop:0 rgba(0, 255, 204, 0.4), 
        stop:0.4 rgba(0, 122, 255, 0.1), 
        stop:1 rgba(0, 0, 0, 0));
    color: #00ffcc; 
    font-size: 17px; 
    border: 1px solid #005bb5; 
    border-left: 6px solid #00ffcc; 
    padding-left: 10px; 
}</string>
   </property>
   <property name="frameShape">
    <enum>QFrame::StyledPanel</enum>
   </property>
   <property name="frameShadow">
    <enum>QFrame::Raised</enum>
   </property>
